<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Sharp"
    Manufacturer="Sharp Project"
    Version="0.1.0"
    UpgradeCode="D7F0C0E2-3B31-4B08-949D-365D49D9F0B2"
    Language="1033"
    Scope="perUser"
    InstallerVersion="500"
    Compressed="yes">
    <SummaryInformation Description="Sharp Installer" Manufacturer="Sharp Project" />
    <MajorUpgrade DowngradeErrorMessage="A newer version of Sharp is already installed." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Icon Id="SharpIcon" SourceFile="installer\spear.ico" />
    <Property Id="ARPPRODUCTICON" Value="SharpIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/example/sharp" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/example/sharp" />
    <Property Id="ARPCONTACT" Value="Sharp Project" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="Sharp">
          <Directory Id="RuntimeFolder" Name="runtime" />
          <Directory Id="StdFolder" Name="std">
            <Directory Id="StdMathFolder" Name="math" />
            <Directory Id="StdTextFolder" Name="text" />
            <Directory Id="StdCollectionsFolder" Name="collections" />
            <Directory Id="StdIoFolder" Name="io" />
            <Directory Id="StdSystemFolder" Name="system" />
            <Directory Id="StdBridgeFolder" Name="bridge" />
            <Directory Id="StdWebFolder" Name="web" />
          </Directory>
          <Directory Id="ExamplesFolder" Name="examples" />
          <Directory Id="VSCodeFolder" Name="vscode-spear">
            <Directory Id="VSCodeAssetsFolder" Name="assets" />
            <Directory Id="VSCodeSnippetsFolder" Name="snippets" />
            <Directory Id="VSCodeSyntaxesFolder" Name="syntaxes" />
            <Directory Id="VSCodeThemesFolder" Name="themes" />
          </Directory>
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Sharp" />
    </StandardDirectory>

    <Feature Id="MainFeature" Title="Sharp" Level="1">
      <ComponentRef Id="CmpSharpExe" />
      <ComponentRef Id="CmpSharpcExe" />
      <ComponentRef Id="CmpSharpSetupExe" />
      <ComponentRef Id="CmpSpearExe" />
      <ComponentRef Id="CmpSpearcExe" />
      <ComponentRef Id="CmpSetupExe" />
      <ComponentRef Id="CmpRuntimeBridgeNode" />
      <ComponentRef Id="CmpRuntimeBridgePython" />
      <ComponentRef Id="CmpRuntimeDemoNode" />
      <ComponentRef Id="CmpRuntimeDemoPython" />
      <ComponentRef Id="CmpRuntimeServeStatic" />
      <ComponentRef Id="CmpRuntimeSqlite" />
      <ComponentRef Id="CmpRuntimeSharpcBackend" />
      <ComponentRef Id="CmpStdPrelude" />
      <ComponentRef Id="CmpStdMathFacade" />
      <ComponentRef Id="CmpStdTextFacade" />
      <ComponentRef Id="CmpStdListsFacade" />
      <ComponentRef Id="CmpStdIoFacade" />
      <ComponentRef Id="CmpStdPathsFacade" />
      <ComponentRef Id="CmpStdAssertFacade" />
      <ComponentRef Id="CmpStdBridgeFacade" />
      <ComponentRef Id="CmpStdWebFacade" />
      <ComponentRef Id="CmpStdMathArithmetic" />
      <ComponentRef Id="CmpStdMathCompare" />
      <ComponentRef Id="CmpStdTextBuilders" />
      <ComponentRef Id="CmpStdTextLayout" />
      <ComponentRef Id="CmpStdCollectionsListsBase" />
      <ComponentRef Id="CmpStdIoConsole" />
      <ComponentRef Id="CmpStdIoFiles" />
      <ComponentRef Id="CmpStdSystemPathsBase" />
      <ComponentRef Id="CmpStdSystemAssertsBase" />
      <ComponentRef Id="CmpStdBridgeNodeBase" />
      <ComponentRef Id="CmpStdBridgePythonBase" />
      <ComponentRef Id="CmpStdWebLayout" />
      <ComponentRef Id="CmpStdWebContent" />
      <ComponentRef Id="CmpStdWebActions" />
      <ComponentRef Id="CmpExampleBridge" />
      <ComponentRef Id="CmpExampleHello" />
      <ComponentRef Id="CmpExampleMath" />
      <ComponentRef Id="CmpExampleWeb" />
      <ComponentRef Id="CmpVsExtension" />
      <ComponentRef Id="CmpVsLanguageConfig" />
      <ComponentRef Id="CmpVsPackage" />
      <ComponentRef Id="CmpVsReadme" />
      <ComponentRef Id="CmpVsLogoPng" />
      <ComponentRef Id="CmpVsLogoSvg" />
      <ComponentRef Id="CmpVsSnippets" />
      <ComponentRef Id="CmpVsSyntax" />
      <ComponentRef Id="CmpVsTheme" />
      <ComponentRef Id="CmpStartMenuShortcut" />
    </Feature>

    <Component Id="CmpSharpExe" Directory="INSTALLFOLDER" Guid="*">
      <File Id="FileSharpExe" Source="$(var.SourceDir)\sharp.exe" KeyPath="yes" />
    </Component>

    <Component Id="CmpSharpcExe" Directory="INSTALLFOLDER" Guid="*">
      <File Id="FileSharpcExe" Source="$(var.SourceDir)\sharpc.exe" KeyPath="yes" />
    </Component>

    <Component Id="CmpSharpSetupExe" Directory="INSTALLFOLDER" Guid="*">
      <File Id="FileSharpSetupExe" Source="$(var.SourceDir)\sharp-setup.exe" KeyPath="yes" />
    </Component>

    <Component Id="CmpSpearExe" Directory="INSTALLFOLDER" Guid="*">
      <File Id="FileSpearExe" Source="$(var.SourceDir)\spear.exe" KeyPath="yes" />
    </Component>

    <Component Id="CmpSpearcExe" Directory="INSTALLFOLDER" Guid="*">
      <File Id="FileSpearcExe" Source="$(var.SourceDir)\spearc.exe" KeyPath="yes" />
    </Component>

    <Component Id="CmpSetupExe" Directory="INSTALLFOLDER" Guid="*">
      <File Id="FileSetupExe" Source="$(var.SourceDir)\spear-setup.exe" KeyPath="yes" />
    </Component>

    <Component Id="CmpRuntimeBridgeNode" Directory="RuntimeFolder" Guid="*">
      <File Id="FileRuntimeBridgeNode" Source="$(var.SourceDir)\runtime\bridge_node.mjs" KeyPath="yes" />
    </Component>

    <Component Id="CmpRuntimeBridgePython" Directory="RuntimeFolder" Guid="*">
      <File Id="FileRuntimeBridgePython" Source="$(var.SourceDir)\runtime\bridge_python.py" KeyPath="yes" />
    </Component>

    <Component Id="CmpRuntimeDemoNode" Directory="RuntimeFolder" Guid="*">
      <File Id="FileRuntimeDemoNode" Source="$(var.SourceDir)\runtime\demo_node.cjs" KeyPath="yes" />
    </Component>

    <Component Id="CmpRuntimeDemoPython" Directory="RuntimeFolder" Guid="*">
      <File Id="FileRuntimeDemoPython" Source="$(var.SourceDir)\runtime\demo_python.py" KeyPath="yes" />
    </Component>

    <Component Id="CmpRuntimeServeStatic" Directory="RuntimeFolder" Guid="*">
      <File Id="FileRuntimeServeStatic" Source="$(var.SourceDir)\runtime\serve_static.ps1" KeyPath="yes" />
    </Component>

    <Component Id="CmpRuntimeSqlite" Directory="RuntimeFolder" Guid="*">
      <File Id="FileRuntimeSqlite" Source="$(var.SourceDir)\runtime\sqlite3.exe" KeyPath="yes" />
    </Component>

    <Component Id="CmpRuntimeSharpcBackend" Directory="RuntimeFolder" Guid="*">
      <File Id="FileRuntimeSharpcBackend" Source="$(var.SourceDir)\runtime\sharpc-c.exe" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdPrelude" Directory="StdFolder" Guid="*">
      <File Id="FileStdPrelude" Source="$(var.SourceDir)\std\prelude.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdMathFacade" Directory="StdFolder" Guid="*">
      <File Id="FileStdMath" Source="$(var.SourceDir)\std\math.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdTextFacade" Directory="StdFolder" Guid="*">
      <File Id="FileStdText" Source="$(var.SourceDir)\std\text.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdListsFacade" Directory="StdFolder" Guid="*">
      <File Id="FileStdLists" Source="$(var.SourceDir)\std\lists.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdIoFacade" Directory="StdFolder" Guid="*">
      <File Id="FileStdIo" Source="$(var.SourceDir)\std\io.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdPathsFacade" Directory="StdFolder" Guid="*">
      <File Id="FileStdPaths" Source="$(var.SourceDir)\std\paths.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdAssertFacade" Directory="StdFolder" Guid="*">
      <File Id="FileStdAssert" Source="$(var.SourceDir)\std\assert.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdBridgeFacade" Directory="StdFolder" Guid="*">
      <File Id="FileStdBridge" Source="$(var.SourceDir)\std\bridge.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdWebFacade" Directory="StdFolder" Guid="*">
      <File Id="FileStdWeb" Source="$(var.SourceDir)\std\web.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdMathArithmetic" Directory="StdMathFolder" Guid="*">
      <File Id="FileStdMathArithmetic" Source="$(var.SourceDir)\std\math\arithmetic.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdMathCompare" Directory="StdMathFolder" Guid="*">
      <File Id="FileStdMathCompare" Source="$(var.SourceDir)\std\math\compare.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdTextBuilders" Directory="StdTextFolder" Guid="*">
      <File Id="FileStdTextBuilders" Source="$(var.SourceDir)\std\text\builders.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdTextLayout" Directory="StdTextFolder" Guid="*">
      <File Id="FileStdTextLayout" Source="$(var.SourceDir)\std\text\layout.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdCollectionsListsBase" Directory="StdCollectionsFolder" Guid="*">
      <File Id="FileStdCollectionsListsBase" Source="$(var.SourceDir)\std\collections\lists_base.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdIoConsole" Directory="StdIoFolder" Guid="*">
      <File Id="FileStdIoConsole" Source="$(var.SourceDir)\std\io\console.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdIoFiles" Directory="StdIoFolder" Guid="*">
      <File Id="FileStdIoFiles" Source="$(var.SourceDir)\std\io\files.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdSystemPathsBase" Directory="StdSystemFolder" Guid="*">
      <File Id="FileStdSystemPathsBase" Source="$(var.SourceDir)\std\system\paths_base.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdSystemAssertsBase" Directory="StdSystemFolder" Guid="*">
      <File Id="FileStdSystemAssertsBase" Source="$(var.SourceDir)\std\system\asserts_base.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdBridgeNodeBase" Directory="StdBridgeFolder" Guid="*">
      <File Id="FileStdBridgeNodeBase" Source="$(var.SourceDir)\std\bridge\node_base.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdBridgePythonBase" Directory="StdBridgeFolder" Guid="*">
      <File Id="FileStdBridgePythonBase" Source="$(var.SourceDir)\std\bridge\python_base.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdWebLayout" Directory="StdWebFolder" Guid="*">
      <File Id="FileStdWebLayout" Source="$(var.SourceDir)\std\web\layout.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdWebContent" Directory="StdWebFolder" Guid="*">
      <File Id="FileStdWebContent" Source="$(var.SourceDir)\std\web\content.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpStdWebActions" Directory="StdWebFolder" Guid="*">
      <File Id="FileStdWebActions" Source="$(var.SourceDir)\std\web\actions.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpExampleBridge" Directory="ExamplesFolder" Guid="*">
      <File Id="FileExampleBridge" Source="$(var.SourceDir)\examples\bridge.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpExampleHello" Directory="ExamplesFolder" Guid="*">
      <File Id="FileExampleHello" Source="$(var.SourceDir)\examples\hello.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpExampleMath" Directory="ExamplesFolder" Guid="*">
      <File Id="FileExampleMath" Source="$(var.SourceDir)\examples\math.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpExampleWeb" Directory="ExamplesFolder" Guid="*">
      <File Id="FileExampleWeb" Source="$(var.SourceDir)\examples\web.sharp" KeyPath="yes" />
    </Component>

    <Component Id="CmpVsExtension" Directory="VSCodeFolder" Guid="*">
      <File Id="FileVsExtension" Source="$(var.SourceDir)\vscode-spear\extension.js" KeyPath="yes" />
    </Component>

    <Component Id="CmpVsLanguageConfig" Directory="VSCodeFolder" Guid="*">
      <File Id="FileVsLanguageConfig" Source="$(var.SourceDir)\vscode-spear\language-configuration.json" KeyPath="yes" />
    </Component>

    <Component Id="CmpVsPackage" Directory="VSCodeFolder" Guid="*">
      <File Id="FileVsPackage" Source="$(var.SourceDir)\vscode-spear\package.json" KeyPath="yes" />
    </Component>

    <Component Id="CmpVsReadme" Directory="VSCodeFolder" Guid="*">
      <File Id="FileVsReadme" Source="$(var.SourceDir)\vscode-spear\README.md" KeyPath="yes" />
    </Component>

    <Component Id="CmpVsLogoPng" Directory="VSCodeAssetsFolder" Guid="*">
      <File Id="FileVsLogoPng" Source="$(var.SourceDir)\vscode-spear\assets\spear-logo.png" KeyPath="yes" />
    </Component>

    <Component Id="CmpVsLogoSvg" Directory="VSCodeAssetsFolder" Guid="*">
      <File Id="FileVsLogoSvg" Source="$(var.SourceDir)\vscode-spear\assets\spear-logo.svg" KeyPath="yes" />
    </Component>

    <Component Id="CmpVsSnippets" Directory="VSCodeSnippetsFolder" Guid="*">
      <File Id="FileVsSnippets" Source="$(var.SourceDir)\vscode-spear\snippets\spear.json" KeyPath="yes" />
    </Component>

    <Component Id="CmpVsSyntax" Directory="VSCodeSyntaxesFolder" Guid="*">
      <File Id="FileVsSyntax" Source="$(var.SourceDir)\vscode-spear\syntaxes\spear.tmLanguage.json" KeyPath="yes" />
    </Component>

    <Component Id="CmpVsTheme" Directory="VSCodeThemesFolder" Guid="*">
      <File Id="FileVsTheme" Source="$(var.SourceDir)\vscode-spear\themes\spear-dark-color-theme.json" KeyPath="yes" />
    </Component>

    <Component Id="CmpStartMenuShortcut" Directory="ApplicationProgramsFolder" Guid="*">
      <Shortcut
        Id="SpearShortcut"
        Name="Sharp"
        Description="Launch the Sharp setup wizard"
        Target="[INSTALLFOLDER]sharp-setup.exe"
        WorkingDirectory="INSTALLFOLDER" />
      <RemoveFolder Id="RemoveApplicationProgramsFolder" Directory="ApplicationProgramsFolder" On="uninstall" />
      <RegistryValue Root="HKCU" Key="Software\Sharp" Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
    </Component>
  </Package>
</Wix>

