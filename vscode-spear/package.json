{
  "name": "sharp-language",
  "displayName": "Sharp Language",
  "description": "Syntax highlighting for the Sharp programming language",
  "version": "0.1.0",
  "publisher": "local",
  "icon": "assets/spear-logo.png",
  "main": "./extension.js",
  "repository": {
    "type": "git",
    "url": "https://example.com/local/spear"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "sharp",
    "sharp",
    "language"
  ],
  "activationEvents": [
    "onLanguage:spear"
  ],
  "contributes": {
    "configuration": {
      "title": "Sharp",
      "properties": {
        "spear.compilerPath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path to sharpc.exe. When empty, the extension uses build/sharpc.exe from the current workspace."
        }
      }
    },
    "languages": [
      {
        "id": "spear",
        "aliases": ["Sharp", "sharp"],
        "extensions": [".sp"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "spear",
        "scopeName": "source.spear",
        "path": "./syntaxes/spear.tmLanguage.json"
      }
    ],
    "themes": [
      {
        "label": "Sharp Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/spear-dark-color-theme.json"
      }
    ],
    "snippets": [
      {
        "language": "spear",
        "path": "./snippets/spear.json"
      }
    ]
  }
}
