{
  "Sharp Entry": {
    "prefix": "Sharp",
    "body": [
      "Sharp launch() {",
      "    $0",
      "}"
    ],
    "description": "Create a Sharp entry function"
  },
  "Sharp Scope": {
    "prefix": "sharp",
    "body": [
      "sharp {",
      "    $0",
      "}"
    ],
    "description": "Create a sharp memory scope"
  },
  "Let Value": {
    "prefix": "let",
    "body": [
      "let ${1:name} = ${2:value};"
    ],
    "description": "Create an inferred variable"
  },
  "Var Value": {
    "prefix": "var",
    "body": [
      "var ${1:name} = ${2:value};"
    ],
    "description": "Create a mutable inferred variable"
  },
  "Const Value": {
    "prefix": "const",
    "body": [
      "const let ${1:name} = ${2:value};"
    ],
    "description": "Create an immutable inferred value"
  },
  "Each Loop": {
    "prefix": "each",
    "body": [
      "each ${1:item} in ${2:list} {",
      "    $0",
      "}"
    ],
    "description": "Iterate through a Sharp list"
  },
  "For Loop": {
    "prefix": "for",
    "body": [
      "for (var ${1:i} = 0; ${1:i} < ${2:limit}; ${1:i} = ${1:i} + 1) {",
      "    $0",
      "}"
    ],
    "description": "Create a numeric for loop"
  },
  "Import": {
    "prefix": "import",
    "body": [
      "import \"${1:module.sp}\";"
    ],
    "description": "Import another Sharp source file"
  },
  "Node Bridge": {
    "prefix": "nodecall",
    "body": [
      "nodecall(\"${1:package}\", \"${2:function}\", \"${3:{}}\")"
    ],
    "description": "Call a Node/npm function through the Sharp bridge"
  },
  "Python Bridge": {
    "prefix": "pycall",
    "body": [
      "pycall(\"${1:module}\", \"${2:function}\", \"${3:{}}\")"
    ],
    "description": "Call a Python/pip function through the Sharp bridge"
  },
  "Num Function": {
    "prefix": "spnum",
    "body": [
      "function num ${1:name}(num ${2:value}) {",
      "    return ${2:value};",
      "}"
    ],
    "description": "Create a numeric function"
  },
  "Text Function": {
    "prefix": "sptext",
    "body": [
      "function text ${1:name}(text ${2:value}) {",
      "    return ${2:value};",
      "}"
    ],
    "description": "Create a text function"
  },
  "View Function": {
    "prefix": "view",
    "body": [
      "view ${1:name}(text ${2:title}, text ${3:body}) {",
      "    return stack(",
      "        markup(\"h1\", escape(${2:title})),",
      "        markup(\"p\", escape(${3:body}))",
      "    );",
      "}"
    ],
    "description": "Create a UI-oriented Sharp view component"
  },
  "HTML Page": {
    "prefix": "page",
    "body": [
      "Sharp launch() {",
      "    const let title = \"${1:Title}\";",
      "    let body = stack(",
      "        markup(\"h1\", escape(title)),",
      "        action(\"/start\", \"${2:Open App}\")",
      "    );",
      "    guard(size(body) > 0, \"body must not be empty\");",
      "    write(\"build/app.html\", page(title, body));",
      "    say(page(title, body));",
      "}"
    ],
    "description": "Create a simple Sharp HTML page"
  }
}

