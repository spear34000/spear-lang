{
  "scopeName": "source.spear",
  "name": "Spear",
  "patterns": [
    { "include": "#comments" },
    { "include": "#imports" },
    { "include": "#metadata" },
    { "include": "#function-definitions" },
    { "include": "#ui-builders" },
    { "include": "#declarations" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#function-calls" },
    { "include": "#punctuation" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.spear",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.spear",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.spear",
              "match": "\\\\[nrt\"\\\\]"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.spear",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "metadata": {
      "patterns": [
        {
          "name": "meta.declaration.package.spear",
          "match": "\\b(package|module)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "keyword.control.spear" },
            "2": { "name": "entity.name.namespace.spear" }
          }
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "name": "meta.import.spear",
          "match": "\\b(import)\\s+(\"(?:\\\\[nrt\"\\\\]|[^\"\\\\])*\")\\s*;",
          "captures": {
            "1": { "name": "keyword.control.import.spear" },
            "2": { "name": "string.quoted.double.spear" }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.import.spear",
          "match": "\\bimport\\b"
        },
        {
          "name": "keyword.control.module.spear",
          "match": "\\b(package|module)\\b"
        },
        {
          "name": "keyword.control.flow.spear",
          "match": "\\b(if|else|for|while|break|continue|return|each|in|throw|try|catch|run|keep)\\b"
        },
        {
          "name": "storage.type.memory.spear",
          "match": "\\bsharp\\b"
        },
        {
          "name": "storage.type.entry.spear",
          "match": "\\bspear\\b"
        },
        {
          "name": "storage.modifier.spear",
          "match": "\\b(function|const)\\b"
        },
        {
          "name": "storage.type.variable.spear",
          "match": "\\b(let|value|var|variable|mutable)\\b"
        },
        {
          "name": "storage.type.function.spear",
          "match": "\\bview\\b"
        },
        {
          "name": "storage.type.spear",
          "match": "\\b(num|number|text|string|numlist|numbers|textlist|strings)\\b"
        }
      ]
    },
    "function-definitions": {
      "patterns": [
        {
          "name": "meta.function.definition.spear",
          "begin": "\\b(?:(function)\\s+)?(?:(spear|view|num|number|text|string|numlist|numbers|textlist|strings))\\s+([A-Za-z_][A-Za-z0-9_]*)\\s*(\\()",
          "beginCaptures": {
            "1": { "name": "storage.modifier.spear" },
            "2": { "name": "storage.type.function.spear" },
            "3": { "name": "entity.name.function.spear" },
            "4": { "name": "punctuation.section.parameters.begin.spear" }
          },
          "end": "(\\))",
          "endCaptures": {
            "1": { "name": "punctuation.section.parameters.end.spear" }
          },
          "patterns": [
            {
              "name": "meta.parameter.spear",
              "match": "\\b(num|number|text|string|numlist|numbers|textlist|strings)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
              "captures": {
                "1": { "name": "storage.type.spear" },
                "2": { "name": "variable.parameter.spear" }
              }
            },
            {
              "name": "punctuation.separator.parameter.spear",
              "match": ","
            }
          ]
        }
      ]
    },
    "ui-builders": {
      "patterns": [
        {
          "name": "meta.ui.builder.call.spear",
          "match": "\\b(markup|page|stack|inline|column|row)\\b\\s*(?=\\(|\\{)",
          "captures": {
            "1": { "name": "support.function.builtin.spear" }
          }
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.variable.declaration.spear",
          "match": "\\b(const)\\s+(?:((?:let|value|var|variable|mutable|num|number|text|string|numlist|numbers|textlist|strings))\\s+)?([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.modifier.spear" },
            "2": { "name": "storage.type.spear" },
            "3": { "name": "variable.other.definition.spear" }
          }
        },
        {
          "name": "meta.variable.declaration.spear",
          "match": "\\b(let|value|var|variable|mutable|num|number|text|string|numlist|numbers|textlist|strings)\\s+([A-Za-z_][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": { "name": "storage.type.spear" },
            "2": { "name": "variable.other.definition.spear" }
          }
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.spear",
          "match": "\\b(say|print|write|join|read|ask|size|same|pack|push|count|at|guard|escape|attr|attrs|class_name|id_name|style_attr|href_attr|src_attr|alt_attr|markup|page|stack|inline|column|row|box|surface_box|column_box|row_box|action|nodecall|pycall|sharpen)\\b\\s*(?=\\(|\\{)"
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "entity.name.function.call.spear",
          "match": "\\b(?!(?:if|else|for|while|return|each|in|function|let|value|var|variable|mutable|const|view|package|module|import|throw|try|catch|class|run|keep|say|print|write|join|read|ask|size|same|pack|push|count|at|guard|escape|attr|attrs|class_name|id_name|style_attr|href_attr|src_attr|alt_attr|markup|page|stack|inline|column|row|box|surface_box|column_box|row_box|action|nodecall|pycall|sharpen|num|number|text|string|numlist|numbers|textlist|strings|spear|sharp)\\b)([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.spear" }
          }
        },
        {
          "name": "variable.other.readwrite.spear",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*(?:==|!=|<=|>=|=|\\+|-|\\*|/|%|<|>|,|;|\\)|\\}|\\]))",
          "captures": {
            "1": { "name": "variable.other.spear" }
          }
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.block.begin.spear",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.spear",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.group.begin.spear",
          "match": "\\("
        },
        {
          "name": "punctuation.section.group.end.spear",
          "match": "\\)"
        },
        {
          "name": "punctuation.separator.parameter.spear",
          "match": ","
        },
        {
          "name": "punctuation.terminator.statement.spear",
          "match": ";"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.spear",
          "match": "(==|!=|<=|>=|=|\\+|-|\\*|/|%|<|>)"
        }
      ]
    }
  }
}
